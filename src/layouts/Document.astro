---
import "@styles/global.css"
const { title = "aline" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-background dark:bg-neutral-950 text-foreground dark:text-neutral-100 antialiased selection:bg-neutral-200 dark:selection:bg-neutral-800 transition-colors duration-300">
    <div class="mx-auto max-w-2xl px-6 py-16">
      <header class="mb-16 flex justify-between items-center">
        <a href="/" class="font-medium text-lg tracking-tight">aline.</a>
        <nav class="flex gap-6 text-sm text-neutral-500 dark:text-neutral-400">
          <a href="/blog" class="hover:text-black dark:hover:text-white transition-colors">Blog</a>
          <a href="/notes" class="hover:text-black dark:hover:text-white transition-colors">Notes</a>
          <a href="/projects" class="hover:text-black dark:hover:text-white transition-colors">Projects</a>
        </nav>
      </header>

      <main class="prose prose-neutral dark:prose-invert prose-headings:font-medium prose-headings:tracking-tight prose-a:no-underline hover:prose-a:underline prose-a:text-neutral-600 dark:prose-a:text-neutral-400 hover:prose-a:text-black dark:hover:prose-a:text-white">
        <slot />
      </main>

      <footer class="mt-24 pt-8 border-t border-neutral-100 dark:border-neutral-900 text-xs text-neutral-400 dark:text-neutral-600">
        <p>© {new Date().getFullYear()} — Built with aline</p>
      </footer>
    </div>
  </body>
</html>
